# =====================
# APP
# =====================
APP_NAME="MDS Dental and Aesthetic Clinic"
APP_ENV=local
APP_DEBUG=true
APP_URL=http://localhost
APP_KEY=

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

# =====================
# DATABASE (DOCKER MYSQL)
# =====================
MYSQL_DATABASE=
MYSQL_ROOT_PASSWORD=
MYSQL_PORT=3306

DB_CONNECTION=mysql
DB_HOST=mysql
DB_PORT=3306
DB_DATABASE=
DB_USERNAME=root
DB_PASSWORD=

# =====================
# SESSION / CACHE
# =====================
SESSION_DRIVER=file
SESSION_LIFETIME=120
CACHE_STORE=file

# =====================
# REDIS (optional future)
# =====================
REDIS_HOST=redis
REDIS_PORT=6379

# =====================
# MAIL (DO NOT COMMIT REAL CREDENTIALS)
# =====================
MAIL_MAILER=smtp
MAIL_HOST=
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS=
MAIL_FROM_NAME="${APP_NAME}"

# =====================
# NEXT.JS
# =====================
NEXT_PORT=3000
NEXT_PUBLIC_API_URL=http://localhost:8000

# =====================
# LARAVEL SERVER
# =====================
LARAVEL_PORT=8000